# Copy to .env.local and replace placeholders with real values.
# .env in the repo should keep placeholders only.
#
# IMPORTANT: DATABASE_URL and DIRECT_URL must ONLY exist in .env.local.
# Never duplicate them in .env — Prisma injects both files and conflicting
# passwords cause P1000 authentication errors.

PORT=4000

# Database (Supabase PostgreSQL) — configure in .env.local only
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# Cloudflare R2 (S3 Compatibility API)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://media.yourdomain.com

# Optional services
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key
REDIS_URL=redis://localhost:6379

# Supabase Auth (for API route JWT validation — server-only, not NEXT_PUBLIC_)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=
