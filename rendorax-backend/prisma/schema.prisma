generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

enum MediaProcessingStatus {
  queued
  probing
  transcoding
  uploading
  ready
  failed

  @@schema("public")
}

enum MediaPlaybackFormat {
  hls
  progressive
  none

  @@schema("public")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  category    String
  videoUrl    String?
  thumbnail   String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model Message {
  id        String   @id @default(uuid())
  email     String
  subject   String
  content   String
  createdAt DateTime @default(now())

  @@schema("public")
}

model MediaAsset {
  id                String               @id @default(uuid())
  fileName          String
  publicUrl         String
  thumbnailUrl      String?
  objectKey         String?
  mimeType          String
  fileSize          Int?
  folder            String?
  userId            String?
  agencyProjectId   String?
  durationMs        Int?
  width             Int?
  height            Int?
  frameRate         Float?
  playbackObjectKey String?
  playbackFormat    MediaPlaybackFormat?
  processingStatus  MediaProcessingStatus?
  proxyVersion      Int                  @default(1)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  processingJobs         MediaProcessingJob[]
  reviewVersionDecisions ReviewVersionDecision[]
  pictureLockEvents      PictureLockEvent[]
  masterDeliveryEvents   MasterDeliveryEvent[] @relation("MasterDeliveryAsset")
  masterDeliverySources  MasterDeliveryEvent[] @relation("MasterDeliverySourceReview")
  masterDeliveryDownloadEvents MasterDeliveryDownloadEvent[]
  agencyProject          AgencyProject?       @relation(fields: [agencyProjectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([agencyProjectId])
  @@index([objectKey])
  @@index([createdAt])
  @@index([processingStatus])
  @@schema("public")
}

model MediaProcessingJob {
  id           String                @id @default(uuid())
  assetId      String
  status       MediaProcessingStatus @default(queued)
  progress     Int                   @default(0)
  errorCode    String?
  errorMessage String?
  workerId     String?
  attempts     Int                   @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  asset        MediaAsset            @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([status])
  @@index([createdAt])
  @@schema("public")
}

model MediaFolder {
  id        String   @id @default(uuid())
  path      String
  userId    String
  createdAt DateTime @default(now())

  @@unique([userId, path])
  @@index([userId])
  @@schema("public")
}

// ── Agency Management ────────────────────────────────────────────────────────
// Portfolio showcase projects remain in the `Project` model above.
// Agency workflow projects live in `AgencyProject` to avoid a naming collision.

enum AgencyRole {
  admin
  editor
  client

  @@schema("public")
}

enum TaskStatus {
  todo
  in_progress
  in_review
  done

  @@schema("public")
}

enum ReviewDecisionStatus {
  submitted_for_review
  approved
  revision_requested
  admin_override

  @@schema("public")
}

enum PictureLockEventType {
  locked
  unlocked

  @@schema("public")
}

enum MasterDeliveryEventType {
  delivered
  replaced
  restored
  expired

  @@schema("public")
}

/// Pre-project intake status. Approval comes from Client Proposal accept (Phase 2).
/// Conversion to AgencyProject is Phase 4 (Admin only).
enum ProjectRequestStatus {
  submitted
  needs_clarification
  under_review
  quoted
  approved
  rejected
  converted_to_project

  @@schema("public")
}

enum ProjectProposalStatus {
  draft
  sent
  changes_requested
  approved
  rejected

  @@schema("public")
}

enum ClientOrganizationRole {
  primary_contact
  reviewer
  stakeholder
  approver
  observer

  @@schema("public")
}

enum ClientOrganizationMemberStatus {
  invited
  active
  removed

  @@schema("public")
}

enum MasterDeliveryDownloadEventType {
  access_granted

  @@schema("public")
}

/// Studio team member — `id` matches Supabase `auth.users.id`.
model User {
  id             String          @id
  email          String          @unique
  displayName    String?
  role           AgencyRole      @default(editor)
  /// Editor staffing metadata only — not an auth role. Null for clients/admins/legacy editors.
  specialization String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assignedTasks          Task[]
  ownedProjects          AgencyProject[]         @relation("ProjectOwner")
  clientProjects         AgencyProject[]         @relation("ProjectClient")
  reviewVersionDecisions ReviewVersionDecision[]
  pictureLockEvents      PictureLockEvent[]
  masterDeliveryEvents   MasterDeliveryEvent[]
  masterDeliveryDownloadEvents MasterDeliveryDownloadEvent[]
  primaryContactOrganization ClientOrganization?
  submittedProjectRequests   ProjectRequest[]
  proposalsCreated           ProjectProposal[] @relation("ProposalCreatedBy")
  proposalsApproved          ProjectProposal[] @relation("ProposalApprovedBy")
  convertedProjectRequests   ProjectRequest[]  @relation("ProjectRequestConvertedBy")
  organizationMemberships    ClientOrganizationMember[] @relation("ClientOrganizationMemberUser")
  organizationInvitesSent    ClientOrganizationMember[] @relation("ClientOrganizationMemberInvitedBy")
  organizationInvitationsCreated ClientOrganizationInvitation[]

  @@schema("public")
}

/// Client organization. primaryContactUserId remains canonical for AgencyProject.clientId.
model ClientOrganization {
  id                   String           @id @default(uuid())
  name                 String
  primaryContactUserId String           @unique
  primaryContact       User             @relation(fields: [primaryContactUserId], references: [id], onDelete: Restrict)
  projectRequests      ProjectRequest[]
  members              ClientOrganizationMember[]
  invitations          ClientOrganizationInvitation[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([name])
  @@schema("public")
}

model ClientOrganizationMember {
  id              String                         @id @default(uuid())
  organizationId  String
  userId          String?
  email           String
  displayName     String?
  role            ClientOrganizationRole
  status          ClientOrganizationMemberStatus @default(invited)
  invitedByUserId String
  invitedAt       DateTime                       @default(now())
  acceptedAt      DateTime?
  removedAt       DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  organization ClientOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?              @relation("ClientOrganizationMemberUser", fields: [userId], references: [id], onDelete: SetNull)
  invitedBy    User               @relation("ClientOrganizationMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@unique([organizationId, email])
  @@index([userId])
  @@index([organizationId, status])
  @@schema("public")
}

/// Single-use invite. Raw token is never stored — only tokenHash.
model ClientOrganizationInvitation {
  id              String                 @id @default(uuid())
  organizationId  String
  invitedByUserId String
  email           String
  displayName     String?
  role            ClientOrganizationRole
  tokenHash       String                 @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime               @default(now())

  organization ClientOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User               @relation(fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([organizationId, email])
  @@index([expiresAt])
  @@schema("public")
}

/// Pre-project brief intake. Converted to AgencyProject only via Admin convert (Phase 4).
model ProjectRequest {
  id                       String               @id @default(uuid())
  organizationId           String
  submittedByUserId        String
  title                    String
  projectType              String
  description              String
  referenceLinks           String?
  deadlineAt               DateTime?
  deliverables             String
  budgetRange              String?
  status                   ProjectRequestStatus @default(submitted)
  adminNote                String?
  convertedAgencyProjectId String?              @unique
  convertedAt              DateTime?
  convertedByUserId        String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  organization           ClientOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy            User               @relation(fields: [submittedByUserId], references: [id], onDelete: Restrict)
  proposals              ProjectProposal[]
  convertedAgencyProject AgencyProject?     @relation("ProjectRequestConvertedProject", fields: [convertedAgencyProjectId], references: [id], onDelete: SetNull)
  convertedBy            User?              @relation("ProjectRequestConvertedBy", fields: [convertedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([status, createdAt])
  @@index([submittedByUserId])
  @@index([convertedByUserId])
  @@schema("public")
}

/// Versioned commercial proposal for a Project Request. Does not create AgencyProject.
model ProjectProposal {
  id                 String                @id @default(uuid())
  requestId          String
  createdByUserId    String
  approvedByUserId   String?
  version            Int                   @default(1)
  estimatedCostCents Int
  currency           String                @default("USD")
  timelineText       String
  deliverablesText   String
  notes              String?
  termsText          String?
  status             ProjectProposalStatus @default(draft)
  sentAt             DateTime?
  respondedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  request    ProjectRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdBy  User           @relation("ProposalCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedBy User?          @relation("ProposalApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([requestId, version])
  @@index([requestId, status])
  @@schema("public")
}

model AgencyProject {
  id             String       @id @default(uuid())
  title          String
  description    String?
  status         String       @default("Awaiting Assets")
  deadline       DateTime?
  videoLength    String?
  editingStyle   String?
  referenceLinks String?
  ownerId        String
  clientId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  archivedAt     DateTime?
  owner          User         @relation("ProjectOwner", fields: [ownerId], references: [id])
  client         User?        @relation("ProjectClient", fields: [clientId], references: [id], onDelete: SetNull)
  tasks                  Task[]
  assets                 MediaAsset[]
  reviewVersionDecisions ReviewVersionDecision[]
  pictureLockEvents      PictureLockEvent[]
  masterDeliveryEvents   MasterDeliveryEvent[]
  masterDeliveryDownloadEvents MasterDeliveryDownloadEvent[]
  convertedFromRequest   ProjectRequest? @relation("ProjectRequestConvertedProject")

  @@index([ownerId])
  @@index([clientId])
  @@index([status])
  @@index([archivedAt])
  @@schema("public")
}

model Task {
  id          String        @id @default(uuid())
  title       String
  description String?
  status      TaskStatus    @default(todo)
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     AgencyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?         @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@schema("public")
}

model ReviewVersionDecision {
  id              String               @id @default(uuid())
  mediaAssetId    String
  agencyProjectId String
  status          ReviewDecisionStatus
  actorId         String
  actorRole       AgencyRole
  note            String?
  createdAt       DateTime             @default(now())
  mediaAsset      MediaAsset           @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  agencyProject   AgencyProject        @relation(fields: [agencyProjectId], references: [id], onDelete: Cascade)
  actor           User                 @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([mediaAssetId, createdAt])
  @@index([agencyProjectId, createdAt])
  @@schema("public")
}

model PictureLockEvent {
  id              String               @id @default(uuid())
  mediaAssetId    String
  agencyProjectId String
  actorId         String
  actorRole       AgencyRole
  eventType       PictureLockEventType
  integrityHash   String?
  objectKey       String?
  note            String?
  createdAt       DateTime             @default(now())
  mediaAsset      MediaAsset           @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  agencyProject   AgencyProject        @relation(fields: [agencyProjectId], references: [id], onDelete: Cascade)
  actor           User                 @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([mediaAssetId, createdAt])
  @@index([agencyProjectId, createdAt])
  @@schema("public")
}

model MasterDeliveryEvent {
  id                  String                  @id @default(uuid())
  mediaAssetId        String
  agencyProjectId     String
  actorId             String
  actorRole           AgencyRole
  eventType           MasterDeliveryEventType
  sourceReviewAssetId String?
  note                String?
  createdAt           DateTime                @default(now())

  mediaAsset        MediaAsset    @relation("MasterDeliveryAsset", fields: [mediaAssetId], references: [id], onDelete: Cascade)
  agencyProject     AgencyProject @relation(fields: [agencyProjectId], references: [id], onDelete: Cascade)
  actor             User          @relation(fields: [actorId], references: [id], onDelete: Restrict)
  sourceReviewAsset MediaAsset?   @relation("MasterDeliverySourceReview", fields: [sourceReviewAssetId], references: [id], onDelete: SetNull)
  downloadEvents    MasterDeliveryDownloadEvent[]

  @@index([mediaAssetId, createdAt])
  @@index([agencyProjectId, createdAt])
  @@index([sourceReviewAssetId])
  @@schema("public")
}

/// Append-only audit: signed Master Delivery download URL issued (not download completion).
model MasterDeliveryDownloadEvent {
  id                    String                          @id @default(uuid())
  masterDeliveryEventId String
  mediaAssetId          String
  agencyProjectId       String
  actorId               String
  actorRole             AgencyRole
  eventType             MasterDeliveryDownloadEventType @default(access_granted)
  createdAt             DateTime                        @default(now())

  masterDeliveryEvent MasterDeliveryEvent @relation(fields: [masterDeliveryEventId], references: [id], onDelete: Cascade)
  mediaAsset    MediaAsset    @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  agencyProject AgencyProject @relation(fields: [agencyProjectId], references: [id], onDelete: Cascade)
  actor         User          @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([masterDeliveryEventId, createdAt])
  @@index([mediaAssetId, createdAt])
  @@index([agencyProjectId, createdAt])
  @@index([actorId, createdAt])
  @@schema("public")
}
