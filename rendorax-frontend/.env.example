# Copy to .env.local and replace placeholders with real values.

# Public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Demo Workspace Queue exclusion (public IDs only — not passwords; leave empty until seeded)
# NEXT_PUBLIC_DEMO_AGENCY_PROJECT_ID=
# NEXT_PUBLIC_DEMO_CLIENT_USER_ID=
# NEXT_PUBLIC_DEMO_EDITOR_USER_ID=

# Server-only (Next.js API routes / server components — never use NEXT_PUBLIC_ prefix)
REDIS_URL=redis://localhost:6379
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_WEBHOOK_SECRET=your_webhook_secret
GEMINI_API_KEY=your_gemini_api_key
PRIVATE_REEL_PASSCODE=your_private_reel_passcode
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Client organization invitations (optional — if unset, invite UI shows a copyable link)
# RESEND_API_KEY=re_xxxxxxxx
# Optional From override for Resend; default uses onboarding@resend.dev in code

# Public app origin for invite links generated by the backend (no trailing slash)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Password recovery — allow these in Supabase Auth → Redirect URLs:
#   {origin}/auth/callback
#   {origin}/reset-password

# AWS Elemental MediaConvert (optional — not Cloudflare R2)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_MEDIACONVERT_ENDPOINT=https://xyz.mediaconvert.us-east-1.amazonaws.com
AWS_MEDIACONVERT_ROLE_ARN=arn:aws:iam::123456789012:role/MediaConvertRole
AWS_S3_PROXY_BUCKET=your_mediaconvert_proxy_bucket
